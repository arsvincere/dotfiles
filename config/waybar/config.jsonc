// -*- mode: jsonc -*-
{
    // Modules order ---------------------------------------------------------
    "modules-left": [
        "custom/diary",
        "custom/book",
        "custom/calculator",
        "custom/note",
        "custom/english",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "hyprland/language",
        "pulseaudio",
        "network",
        "cpu",
        "memory",
        "disk",
        "temperature"
        // "custom/power"
    ],

    // Modules configuration -------------------------------------------------

    "custom/diary": {
      "format": " ",
      "on-click": "alacritty -T diary -e nvim ~/db/diary",
      "tooltip": false
    },
    "custom/book": {
      "format": " ",
      "on-click": "fbreader",
      "tooltip": false
    },
    "custom/calculator": {
      "format": " ",
      "on-click": "speedcrunch",
      "tooltip": false
    },
    "custom/english": {
      "format": "󰬰 ",
      "on-click": "alacritty -T english -e nvim ~/db/english.norg ",
      "tooltip": false
    },
    "custom/note": {
      "format": " ",
      "on-click": "alacritty -T note -e nvim ~/db/note.norg ",
      "tooltip": false
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{icon}",
        "format-icons": {
            "1": "avin",
            "2": "math",
            "3": "dev",
            "4": "file",
            "5": "dir",
            "6": "msg",
            "7": "web",
            "8": "edit",
            "9": "read",
            "10": "draw",
            "11": "zsh",
            "12": "trade",
            "13": "cfg",
            "14": "view",
            "15": "tmp",
            "urgent": " ",
            "focused": " ",
            "default": " "
        }
    },
    "clock": {
        "interval": 1,
        "timezone": "Europe/Moscow",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": " {:%H:%M   %a %e %B}",
        "format-alt": " {:%H:%M:%S   %a %Y-%m-%d}"
    },
    "hyprland/language": {
        "format": "[{short}]"
    },
    "pulseaudio": {
        "scroll-step": 10,
        "format": "  {volume}",
        "format-muted": " mute",
        "on-click": "pavucontrol",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "headphone": " ",
        "format-icons": {
            "default": ["", " ", " "]
        },
    },

    "network": {
        // "format-wifi": "  {signalStrength}",
        "format-ethernet": "  80",
        "format-disconnected": "󰖪 --",
        "format-alt": "{essid} - {ifname}: {ipaddr}/{cidr}",
        "tooltip-format": "{ifname}: {essid} {ipaddr}/{cidr}"
    },
    "cpu": {
        "format": " {usage}"
    },
    "memory": {
        "format": " {used}"
    },
    "disk": {
        "interval": 30,
        "format": " {specific_used:0.2f}",
        "unit": "GB",
        "tooltip-format": "used: {used} free: {free} total: {total}"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}°",
        "format-critical": "{icon} {temperatureC}°",
        "format-icons": ["", "", ""]
    },
    "custom/power": {
      "format": " ",
      "on-click": "alacritty -e shutdown now",
      "tooltip": false
    }
}

