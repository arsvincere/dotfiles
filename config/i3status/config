# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        output_format = "i3bar"
        colors = true
        interval = 5
        color_good = "#76946a" # Light green
        color_degraded = "#dca561" # Light yellow
        color_bad = "#c34043" # Light red
}

# order += "ipv6"
# order += "ethernet _first_"
# order += "wireless _first_"
# order += "battery all"
order += "load"
order += "memory"
order += "disk /"
# order += "battery 0"
order += "volume master"
order += "tztime local"

ethernet _first_ {
        format_up = "E: %ip (%speed)"
        format_down = "E: down"
}

wireless _first_ {
        format_up = "  %ip"
#         format_up = "W: (%quality at %essid) %ip"
        format_down = "  Down"
}

# battery all {
#         format = "%status %percentage"
# }

load {
        format = "|  CPU: %1min%"
}

memory {
        format = "RAM: %used / %available"
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

disk "/" {
        format = "SDD: %used / %avail  |"
}

battery 0 {
        format = "%status %percentage"
        hide_seconds = true
        integer_battery_capacity = true
        last_full_capacity = true
        status_chr = " +"
        status_bat = ""
        status_full = ""
}

volume master {
        format = "  %volume"
        format_muted = " mute"
        device = "default"
        mixer = "Master"
        mixer_idx = 0
}

tztime local {
        format = "  %Y-%m-%d %a    %H:%M:%S"
}
